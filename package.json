{
  "package_version": 2,
  "version": "0.1.0",
  "name": "ccgf-kit",
  "description": "ccgf runtime framework extension",
  "author": "MikForge",
  "editor": ">=3.8.0",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json"
  },
  "contributions": {
    "asset-db": {
      "mount": {
        "path": "./assets",
        "readonly": false
      }
    },
    "menu": [
      {
        "path": "扩展/ccgf-kit",
        "label": "创建启动场景",
        "message": "create-bootstrap-scene"
      },
      {
        "path": "扩展/ccgf-kit",
        "label": "生成资源映射表",
        "message": "generate-resource-map"
      }
    ],
    "messages": {
      "create-bootstrap-scene": {
        "methods": ["createBootstrapScene"]
      },
      "generate-resource-map": {
        "methods": ["generateResourceMap"]
      }
    }
  }
}
